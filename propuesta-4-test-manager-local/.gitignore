# ── Entorno y secretos ────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── Base de datos ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
# Artefactos de SQLite en WAL mode (los usan backend + qa-worker al mismo tiempo).
*.db-shm
*.db-wal

# ── Tests ─────────────────────────────────────────────────────────────────────
.pytest_cache/
__pycache__/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
dist/
.cache/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── Editores ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Runtime ──────────────────────────────────────────────────────────────────
# Logs del worker generados por start.sh y backups que hace setup.sh
logs/
*.bak
