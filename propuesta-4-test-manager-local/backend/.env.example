# ╔══════════════════════════════════════════════════════════════════════╗
# ║                                                                      ║
# ║   ⚠️   ATENCIÓN — TU API KEY ES PERSONAL                              ║
# ║                                                                      ║
# ║   Tu key del SFR Gateway se cobra a Salesforce y se loguea por       ║
# ║   usuario. Tratala como una contraseña.                              ║
# ║                                                                      ║
# ║   • NO subas este archivo a git (ya está en .gitignore).             ║
# ║   • NO la pegues en Slack, screenshots, Quip ni mensajes.            ║
# ║   • Si la expones por error: rótala INMEDIATAMENTE en la consola     ║
# ║     del SFR Gateway (revoke + reissue).                              ║
# ║   • Cada llamada se loguea con tokens, latencia y costo USD          ║
# ║     estimado. Revisa tu uso en /metrics dentro de la app.            ║
# ║                                                                      ║
# ║   Para configurar este archivo automáticamente, corre:               ║
# ║     ./setup.sh                                                       ║
# ║                                                                      ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Proveedor de IA ───────────────────────────────────────────────────────────
# Solo "openai" está soportado. La app habla con OpenAI directo o con el
# SFR Gateway (auto-detectado por el prefijo de la key).
AI_PROVIDER=openai

# ════════════════════════════════════════════════════════════════════════════
# OBLIGATORIO — SFR Gateway
# ════════════════════════════════════════════════════════════════════════════

# Tu key del SFR Gateway. Es la cadena alfanumérica que te dieron en el
# portal interno (NO empieza con "sk-" — esa sería de OpenAI directo).
OPENAI_API_KEY=tu-key-aqui

# URL base del Gateway. La default es la oficial de Salesforce Research.
# Solo cámbiala si tu equipo te dio una URL distinta.
OPENAI_BASE_URL=https://gateway.salesforceresearch.ai/openai/process/v1

# Modelo a usar. Default: gpt-4o-mini (rápido y económico para iterar).
# Otros aceptados (si tu Gateway los expone): gpt-4o, gpt-4o-2024-08-06,
# gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o1, o1-mini, o3-mini.
OPENAI_MODEL=gpt-4o-mini

# ════════════════════════════════════════════════════════════════════════════
# AVANZADO — déjalo en default si no sabes qué hace
# ════════════════════════════════════════════════════════════════════════════

# Trust Layer del SFR Gateway: filtros de bias, toxicity y prompt-injection.
# Activalos solo si tu equipo los pide. Default: desactivados.
# OPENAI_TRUST_LAYER_BIAS=true
# OPENAI_TRUST_LAYER_TOXICITY=true
# OPENAI_TRUST_LAYER_PROMPT_INJECTION=true

# ── Auth y BD (locales) ──────────────────────────────────────────────────────
# Como esto corre en tu Mac, SQLite es suficiente.
# La DB se crea automáticamente la primera vez que arranca la app.
DATABASE_URL=sqlite:///./qa_manager.db

# Secreto para firmar los tokens JWT de la sesión. Para uso local con SQLite
# el default está bien (la app emite un warning, no error).
# Si quieres uno propio: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga

# Duración del token de sesión. 1440 min = 24 horas.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Operación ────────────────────────────────────────────────────────────────
# Nivel de logs en la terminal donde corre el backend.
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Rate limit por usuario para los endpoints de IA (formato slowapi).
# Como esta versión es para 1 QA en su laptop, este valor casi nunca aplica.
AI_RATE_LIMIT=120/minute

# Tope de historias por lote en /generate-batch.
# Solo evita que un único prompt rompa el max_tokens del modelo.
MAX_BATCH_SIZE=50

# Presupuesto mensual de IA por usuario (USD).
# Default 0 = sin límite. La versión local NO cuenta cuota porque corre en
# tu Mac y la cuota real la decide el SFR Gateway, no esta app.
MONTHLY_BUDGET_USD=0.0

# Default de casos por historia cuando no especificas max_cases.
# Vacío = la IA decide (3-5 típicos).
# DEFAULT_MAX_CASES_PER_STORY=
