# Copia este archivo a `.env` y pega tu Cursor API key.
# Se saca en https://cursor.com/dashboard/cloud-agents → API Keys.
CURSOR_API_KEY=cursor_REEMPLAZA_ESTO

# Opcional. Modelo a usar. Si se omite usa "default" (el server elige).
# Lista válida (mayo 2026): default, claude-sonnet-4-6, claude-opus-4-7,
# gpt-5.5, gpt-5.4, gpt-5.4-mini, gemini-3.1-pro, etc.
# Para listar los disponibles para tu cuenta: Cursor.models.list({ apiKey })
# CURSOR_MODEL_ID=claude-sonnet-4-6
