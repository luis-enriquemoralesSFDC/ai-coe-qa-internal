# API key de Cursor para el SDK. Obtenla en cursor.com/dashboard → API Keys.
# Usa la MISMA key que usaste en executor-spike (el plan/quota es el mismo).
CURSOR_API_KEY=

# Path absoluto al qa_manager.db de FastAPI. El worker abre con WAL mode para
# no chocar con el backend. Default asume estructura de propuesta-4-test-manager-local.
QA_WORKER_DB_PATH=../backend/qa_manager.db

# Modelo por defecto si la fila test_runs no trae model_id explícito.
# claude-haiku-4-5 = más barato, suficiente para casos UI guiados.
# Otras opciones: claude-sonnet-4-6, default (server elige).
QA_WORKER_MODEL_ID=claude-haiku-4-5

# Cada cuánto polea el worker buscando filas queued (en milisegundos).
# 2000ms es suficiente — la latencia percibida en UI no es un cuello de botella
# porque la ejecución del agente toma minutos.
QA_WORKER_POLL_INTERVAL_MS=2000

# Timeout duro por run completo (en milisegundos). Si un run pasa de aquí, el
# worker llama run.cancel() y marca status='error' con error_message='timeout'.
# Default 15 minutos. Casos complejos pueden tomar 5-10 min legítimos; 15 da margen.
QA_WORKER_MAX_RUN_MS=900000

# Tiempo máximo en waiting_login antes de auto-cancelar. Si el QA arranca un
# run y luego se va a comer, no queremos un proceso colgado para siempre.
# Default 30 minutos: cubre logins con MFA + distracciones del QA. Si bajas
# este valor, el QA debe estar listo para loguearse antes de disparar el run.
QA_WORKER_MAX_LOGIN_WAIT_MS=1800000

# Configuración del MCP de Playwright que el agente va a usar. Replica lo que
# tienes en ~/.cursor/mcp.json. El worker pasa esto en cada Agent.create().
# (Si quieres usar Firefox o WebKit en lugar de Chromium, cambia --browser=).
